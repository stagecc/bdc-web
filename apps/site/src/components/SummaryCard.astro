---
import Icon from '@components/Icon.astro';

interface Props {
  icon?: string;
  number: string | number;
  qualifier: string;
  float?: 'left' | 'right';
}

const { icon, number, qualifier, float = 'left' } = Astro.props;

const floatClass =
  float === 'left' ? 'float-left margin-right-2' : 'float-right margin-left-2';
---

<div class={`bg-info-lighter padding-205 margin-bottom-2 width-card-lg ${floatClass}`}>
  {icon && <Icon name={icon} size={6} />}
  <div class="font-heading-2xl text-bold line-height-heading-1">{number}</div>
  <div class="font-sans-md text-bold margin-top-05">{qualifier}</div>
  <slot />
</div>
