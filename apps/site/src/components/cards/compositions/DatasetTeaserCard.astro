---
import CardMediaStack from '@components/cards/patterns/CardMediaStack.astro';

interface Props {
  topic: string;
  title: string;
  summary: string;
  href: string;
  mediaVariant?: 1 | 2 | 3;
  border?: boolean;
}

const { topic, title, summary, href, mediaVariant = 1, border = true } = Astro.props;
---

<CardMediaStack
  eyebrow={topic}
  title={title}
  summary={summary}
  href={href}
  cta="View dataset"
  mediaVariant={mediaVariant}
  border={border}
/>
