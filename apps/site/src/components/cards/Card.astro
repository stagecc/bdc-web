---
interface Props extends astroHTML.JSX.HTMLAttributes<'article'> {
  variant?: 'feature' | 'dataset' | 'panel' | 'testimonial' | 'overview';
  as?: 'article' | 'div';
  border?: boolean;
}

const {
  variant = 'feature',
  as = 'article',
  border = true,
  class: className,
  className: classNameProp,
  ...rest
} = Astro.props;

const Tag = as;
const classes = [
  'card',
  `card--${variant}`,
  'bg-white radius-lg',
  border && 'border border-base-lighter',
  ['feature', 'panel', 'testimonial', 'overview'].includes(variant) &&
    'padding-2',
  className,
  classNameProp,
]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes} {...rest}>
  <slot />
</Tag>

<style>
  .card--dataset {
    overflow: hidden;
  }
</style>
