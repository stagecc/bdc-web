---
import Card from '@components/cards/Card.astro';

interface CardListItem {
  href: string;
  title: string;
  meta: string;
  dateTime?: string;
  secondary?: string;
}

interface Props {
  title: string;
  actionHref: string;
  actionLabel: string;
  items: CardListItem[];
  border?: boolean;
}

const { title, actionHref, actionLabel, items, border = true } = Astro.props;
---

<Card variant="panel" class="card-list" border={border}>
  <div class="card-list__header display-flex flex-justify flex-align-end gap-1 margin-bottom-2">
    <h2 class="margin-0">{title}</h2>
    <a class="card-list__action" href={actionHref}>{actionLabel}</a>
  </div>

  <ul class="card-list__items usa-list usa-list--unstyled margin-0">
    {items.map((item) => (
      <li>
        {item.dateTime ? <time datetime={item.dateTime}>{item.meta}</time> : <p class="margin-0">{item.meta}</p>}
        <a class="card-list__item-link" href={item.href}>{item.title}</a>
        {item.secondary && <p class="margin-0">{item.secondary}</p>}
      </li>
    ))}
  </ul>
</Card>

<style>
  .card-list__header {
    align-items: baseline;
  }

  .card-list__header h2 {
    color: var(--bdc-brand-900);
  }

  .card-list__action {
    color: var(--bdc-brand-700);
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .card-list__action:hover {
    text-decoration: underline;
  }

  .card-list__items li {
    border-top: 1px solid var(--bdc-divider-soft);
    padding: 0.95rem 0;
  }

  .card-list__items li:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .card-list__items li:last-child {
    padding-bottom: 0;
  }

  .card-list__item-link {
    color: var(--bdc-brand-900);
    display: block;
    font-weight: 700;
    margin-bottom: 0.2rem;
    text-decoration: none;
  }

  .card-list__item-link:hover {
    text-decoration: underline;
  }

  .card-list__items p,
  .card-list__items time {
    color: var(--bdc-meta);
    font-size: 0.9rem;
    margin: 0;
  }

  .card-list__items time {
    display: inline-block;
    margin-bottom: 0.25rem;
  }
</style>
