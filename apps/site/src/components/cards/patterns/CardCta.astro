---
import Card from '@components/cards/Card.astro';

interface Props {
  title: string;
  text: string;
  href: string;
  cta: string;
  border?: boolean;
}

const { title, text, href, cta, border = true } = Astro.props;
---

<Card variant="feature" class="card-cta height-full display-flex flex-column" border={border}>
  <h3 class="card-cta__title margin-top-0 margin-bottom-1 flex-1">{title}</h3>
  <p class="card-cta__text margin-top-0 margin-bottom-2">{text}</p>
  <a class="card-cta__link" href={href}>{cta} »</a>
</Card>

<style>
  .card-cta__title {
    color: var(--bdc-brand-900);
    font-size: 1.35rem;
  }

  .card-cta__text {
    color: var(--bdc-copy);
  }

  .card-cta__link {
    color: var(--bdc-brand-700);
    font-weight: 700;
    text-decoration: none;
  }

  .card-cta__link:hover {
    text-decoration: underline;
  }
</style>
