---
import Card from '@components/cards/Card.astro';

interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  href: string;
  cta: string;
  mediaVariant?: 1 | 2 | 3;
  border?: boolean;
}

const {
  eyebrow,
  title,
  summary,
  href,
  cta,
  mediaVariant = 1,
  border = true,
} = Astro.props;
---

<Card variant="dataset" class="card-media-stack" data-variant={mediaVariant} border={border}>
  <div class="card-media-stack__media" aria-hidden="true"></div>
  <div class="card-media-stack__body padding-2">
    <p class="card-media-stack__eyebrow">{eyebrow}</p>
    <h3 class="margin-top-1 margin-bottom-1">{title}</h3>
    <p class="card-media-stack__summary margin-top-0 margin-bottom-2">{summary}</p>
    <a class="card-media-stack__link" href={href}>{cta}</a>
  </div>
</Card>

<style>
  .card-media-stack__media {
    height: 140px;
  }

  .card-media-stack[data-variant='1'] .card-media-stack__media {
    background: linear-gradient(135deg, #7bc4ff, #2866b8);
  }

  .card-media-stack[data-variant='2'] .card-media-stack__media {
    background: linear-gradient(135deg, #8f98ff, #3f4eb5);
  }

  .card-media-stack[data-variant='3'] .card-media-stack__media {
    background: linear-gradient(135deg, #62bad4, #0f5f80);
  }

  .card-media-stack__eyebrow {
    color: var(--bdc-brand-700);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    margin: 0;
    text-transform: uppercase;
  }

  .card-media-stack h3 {
    color: var(--bdc-brand-900);
    font-size: 1.35rem;
  }

  .card-media-stack__summary {
    color: var(--bdc-copy);
  }

  .card-media-stack__link {
    color: var(--bdc-brand-700);
    font-weight: 700;
    text-decoration: none;
  }

  .card-media-stack__link:hover {
    text-decoration: underline;
  }
</style>
