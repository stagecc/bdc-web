---
/**
 * SiteAlert.astro
 *
 * Sitewide banner alert component supporting 5 variants with a gradient
 * background and bottom border accent style.
 *
 * Dismissible per session via sessionStorage — banner reappears on next visit.
 *
 * Accessibility:
 *   - Uses <section> with aria-label for landmark identification.
 *   - Close button is keyboard accessible with descriptive aria-label.
 *
 * Props:
 *   variant      — 'info' | 'warning' | 'error' | 'success' | 'emergency'. Defaults to 'info'.
 *   slim         — Reduces padding. Defaults to false.
 *   title        — Optional heading text.
 *   headingLevel — Heading level for title (h2 | h3 | h4). Defaults to h3.
 *   ariaLabel    — Accessible label for the section. Defaults to 'Site alert'.
 *   storageKey   — Unique key for sessionStorage dismissal. Must be unique per
 *                  banner instance. Use the content collection entry id.
 *
 * Usage:
 *   <SiteAlert variant="warning" storageKey="maintenance-2024">
 *     Scheduled maintenance this weekend.
 *   </SiteAlert>
 *
 */

interface Props {
  variant?: 'info' | 'warning' | 'error' | 'success' | 'emergency';
  slim?: boolean;
  title?: string;
  headingLevel?: 'h2' | 'h3' | 'h4';
  ariaLabel?: string;
  storageKey: string;
}

const {
  variant = 'info',
  slim = false,
  title,
  headingLevel: HeadingTag = 'h3',
  ariaLabel = 'Site alert',
  storageKey,
} = Astro.props;

const alertId = `site-alert-${storageKey}`;

const containerClasses = [
  'usa-site-alert',
  `bdc-site-alert--${variant}`,
  slim && 'usa-site-alert--slim',
]
  .filter(Boolean)
  .join(' ');
---

<section
  class={containerClasses}
  aria-label={ariaLabel}
  id={alertId}
>
  <div class="bdc-site-alert__body">
    <div class="bdc-site-alert__content">
      {title && <HeadingTag class="bdc-site-alert__heading">{title}</HeadingTag>}
      <div class="bdc-site-alert__text">
        <slot />
      </div>
    </div>
    <button
      class="bdc-site-alert__close"
      aria-label="Dismiss alert"
      data-alert-id={alertId}
    >
      ✕
    </button>
  </div>
</section>

<script>
  function initSiteAlerts() {
    document.querySelectorAll('.bdc-site-alert__close').forEach((btn) => {
      const alertId = btn.getAttribute('data-alert-id');
      if (!alertId) return;

      // Hide if already dismissed this session
      if (sessionStorage.getItem(alertId) === 'dismissed') {
        document.getElementById(alertId)?.remove();
        return;
      }

      btn.addEventListener('click', () => {
        sessionStorage.setItem(alertId, 'dismissed');
        document.getElementById(alertId)?.remove();
      });
    });
  }

  // Run on initial page load
  document.addEventListener('DOMContentLoaded', initSiteAlerts);

  // Re-run after Astro view transitions swap the page
  document.addEventListener('astro:after-swap', initSiteAlerts);
</script>
