---
import { isExternalUrl } from '../../util/url';

interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  to: string;
}

const { to, class: className, className: classNameProp, ...rest } = Astro.props;
const isExternal = isExternalUrl(to);
const classes = [
  className,
  classNameProp,
  'usa-link',
  isExternal && 'usa-link--external',
]
  .filter(Boolean)
  .join(' ');
---

<a href={to} class={classes} {...isExternal && { rel: 'noopener', target: '_blank' }} {...rest}><slot /></a>
