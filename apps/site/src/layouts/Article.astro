---
import { Image } from 'astro:assets';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import EmailSignup from '@components/EmailSignup.astro';
import Icon from '@components/Icon.astro';
import ArticleHeader from '@components/news/ArticleHeader.astro';
import Base from '@layouts/Base.astro';

const { frontmatter, newerPost, olderPost, minutesRead } = Astro.props;

const crumbs = [
  { label: 'News', href: '/news/latest-updates/' },
  { label: frontmatter.title },
];

const { title, date, tags, updateType, heroImage, heroAlt } = frontmatter;
---

<Base title={title}>

  <section class="usa-section">
    <article class="article">
      <div class="grid-container">

        <Breadcrumbs items={crumbs} />

        <ArticleHeader
          title={title}
          date={date}
          tags={tags}
          updateType={updateType}
          minutesRead={minutesRead}
        />

        {heroImage && (
          <Image
            src={heroImage}
            alt={heroAlt || ''}
            class="article__hero"
          />
        )}

        {updateType === "Monthly Update" && (
          <div class="usa-card__container">
            <p class="margin-0 font-sans-sm">
              Read the latest monthly update, including recent ecosystem news, data 
              updates, events, training opportunities, and reminders for the BDC community. 
              This update opens in Mailchimp.
            </p>
          </div>
        )}
        {updateType === "Release Notes" && (
          <div class="usa-card__container">
            <p class="margin-0 font-sans-sm">
              The BDC release notes summarize recent updates across the BDC ecosystem, 
              including data availability, documentation, and platform functionality.
            </p>
          </div>
        )}

        <div class="article__content clearfix">
          <slot />
        </div>

        {
          (updateType == "Monthly Update" || updateType == "Release Notes") && (
            <EmailSignup/>
          )
        }
        
        <nav aria-label="More news articles" class="margin-top-10">
          <div class="display-flex flex-justify grid-row">
            {olderPost && (
              <a href={`/news/latest-updates/${olderPost.id}/`} rel="prev" class="grid-col-4">
                ← PREVIOUS
                <span class="usa-collection__meta-item">
                  {olderPost.data.title}
                </span>
              </a>
            )}
            {newerPost && (
              <a href={`/news/latest-updates/${newerPost.id}/`} rel="next" class="grid-col-4 text-right">
                NEXT →
                <span class="usa-collection__meta-item">
                  {newerPost.data.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      </div>
    </article>
  </section>

</Base>

<style>
  .article__content {
    line-height: 1.5;
    blockquote {
      font-size: 1.25rem;
      font-style: italic;
      position: relative;
      margin: 4rem 0 4rem 4rem;
      z-index: 1;
      span.attribution {
        display: block;
        margin-top: 1rem;
        color: #565c65; /* .text-base-dark */
        text-align: right;
        font-size: 75%;
        &::before {
          content: "- ";
        }
      }
      &::before {
        z-index: -1;
        content: "\201C";
        position: absolute;
        top: -3rem;
        left: -2.5rem;
        font-size: 10rem;
        color: #bbcae499;
        font-family: Merriweather;
        line-height: 1;
      }
    }
  }

  .article__hero {
    width: 100%;
    height: auto;
    margin-bottom: 2rem;
    border-radius: 4px;
  }
</style>
