---
import { getCollection } from 'astro:content';
import Link from '@components/link/Link.astro';
import Base from '@layouts/Base.astro';

const programs = (await getCollection('programs')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<Base title="Programs">

  <section class="usa-section">
    <div class="grid-container">

      <h1>Research Community Data</h1>
      <p class="usa-prose">
        Much of the data hosted by BDC comes from collaborations with <Link to="/about/research-communities">research communities</Link>. Click on a Program name in the table below to see a list of datasets from that research community in BDC.
      </p>
      <p class="usa-prose">
        Access to these datasets is limited to those with <Link to="https://public.era.nih.gov/commonsplus/public/login.era?TARGET=https%3A%2F%2Fpublic.era.nih.gov%3A443%2Fcommons">eRA Commons credentials</Link> and approved <Link to="https://dbgap.ncbi.nlm.nih.gov/aa/wga.cgi?page=login">data access requests</Link> through the NIH Database of Genotypes and Phenotypes (dbGaP).
      </p>
      <table class="usa-table usa-table--borderless usa-table--striped width-full">
        <thead>
          <tr>
            <th scope="col">Program</th>
            <th scope="col">Description</th>
            <th scope="col">Datasets</th>
          </tr>
        </thead>
        <tbody>
          {programs.map(program => (
            <tr>
              <th scope="row">
                <Link to={`/about/studies/${program.id}`}>
                  {program.data.name}
                </Link>
              </th>
              <td>{program.data.description}</td>
              <td>{program.data.numberOfStudies}</td>
            </tr>
          ))}
        </tbody>
      </table>

    </div>
  </section>

</Base>
