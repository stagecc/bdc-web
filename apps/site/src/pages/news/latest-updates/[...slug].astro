---
import { render } from 'astro:content';
import ArticleLayout from '@layouts/Article.astro';
import { getEntriesWithNeighbors } from '../../../util/prev-next.ts';

export async function getStaticPaths() {
  const entries = await getEntriesWithNeighbors('news', 'date');

  return entries.map(
    ({ entry: post, newerEntry: newerPost, olderEntry: olderPost }) => ({
      params: {
        slug: post.id,
      },
      props: {
        post,
        newerPost,
        olderPost,
      },
    }),
  );
}

const { post, newerPost, olderPost } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
---

<ArticleLayout
  frontmatter={post.data}
  newerPost={newerPost}
  olderPost={olderPost}
  minutesRead={remarkPluginFrontmatter.minutesRead}
>

  <Content />

</ArticleLayout>