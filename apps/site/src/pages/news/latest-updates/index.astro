---
import { type CollectionEntry, getCollection } from 'astro:content';
import Callout from '@components/Callout.astro';
import Icon from '@components/Icon.astro';
import Link from '@components/link/Link.astro';
import NewsList from '@components/news/NewsList.astro';
import Base from '@layouts/Base.astro';

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// Explicit type, 'news' type is automatically generated from schema in content.config.ts
const postsByYear: Record<number, CollectionEntry<'news'>[]> = {};

for (const post of posts) {
  const year = post.data.date.getFullYear();

  if (!postsByYear[year]) {
    postsByYear[year] = [];
  }

  postsByYear[year].push(post);
}

const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Base title="Latest Updates">

  <section class="usa-section">
    <div class="grid-container">

      <h1>Latest Updates</h1>

      <Callout float="right" >
        <Icon name="mail_outline" size={4}/>

        <p class="text-bold">Never miss an update</p>

        → <Link to="/join-bdc">Click here</Link> to subscribe to receive monthly BDC updates and other announcements.
      </Callout>
      
      <p class="usa-prose">
        Stay current on BDC data releases, ecosystem updates, research highlights, newsletters, and other ecosystem news.
      </p>

      <div class="height-15"></div>

      <p>Showing {posts.length} Updates</p>

      {years.map(year => (
        <section class="margin-top-4">
          <h2 class="font-heading-lg margin-bottom-05">
            {year}
          </h2>
          <NewsList items={postsByYear[year]} />
        </section>
      ))}
    </div>
  </section>

</Base>

