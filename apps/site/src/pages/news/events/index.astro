---
import { getCollection } from 'astro:content';
import Button from '@components/Button.astro';
import EventsList from '@components/events/EventsList.astro';
import Base from '@layouts/Base.astro';
import orgLogo from '../../../../public/favicon.svg';

const now = new Date();

const upcomingEvents = (await getCollection('events'))
  .filter((e) => (e.data.end_date ?? e.data.date) >= now)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const upcoming = upcomingEvents.map((event) => {
  const excerpt = event.body
    ? `${event.body
        .replace(/^---[\s\S]*?---/, '')
        .trim()
        .slice(0, 300)}...`
    : null;
  return { event, excerpt };
});
---

<Base title="Events">

  <section class="usa-section">
    <div class="grid-container">

      <h1>Events</h1>
        <p>
          Explore upcoming webinars, trainings, workshops, conferences, and community sessions from across the BDC ecosystem. 
        </p>
        <p class="usa-prose">
          <img
          src={orgLogo.src}
          alt="org-hosted event"
          width="24"
          height="24"
          class="radius-pill margin-x-05 border-1px border-base-lighter"
        />{" "}<strong>BDC-Hosted</strong> indicates events organized by BDC.
        </p>
      <section class="margin-top-4">
        {upcoming.length > 0
          ? <EventsList items={upcoming} />
          : 'No upcoming events are scheduled at this time. Check back soon!'
        }
      </section>
      <section class="margin-top-4">
        <Button variant="default" centered href="/news/events/archive/">View past events</Button>
      </section>

    </div>
  </section>

</Base>
