---
import { affiliationOptions, projectRoleOptions, teamOptions } from "@components/common/formOptions";
---

<section class="onboarding-form-wrapper maxw-none">
  <h1>Consortium Onboarding Form</h1>

  <p>
    <strong>You must complete this form so that the BDC Coordinating Center (BDC3) can give you full access to BDC Consortium Resources.</strong>
  </p>
  <p>You can save your inputs before submitting by clicking the Save button at the end of the form.</p>
  <p>Hit the Submit button when you have finished filling out all required fields.</p>

  <form id="onboarding-form" class="usa-form maxw-none" action="/consortium-resources/onboarding-form/OnboardingForm/" method="post" novalidate>
    <fieldset class="usa-fieldset">
      <legend class="usa-legend">Section 1</legend>
      <p class="text-base-dark margin-top-1">Provide your primary contact details below.</p>

      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="firstName">First Name</label>
          <input class="usa-input" id="firstName" name="firstName" type="text" required />
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="lastName">Last Name</label>
          <input class="usa-input" id="lastName" name="lastName" type="text" required />
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="email">Email</label>
          <input class="usa-input" id="email" name="email" type="email" required />
        </div>
      </div>
    </fieldset>

    <fieldset class="usa-fieldset margin-top-4">
      <legend class="usa-legend">Section 2</legend>
      <p class="text-base-dark margin-top-1">Fields marked with <span class="text-secondary-vivid">*</span> are required.</p>

      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="team">Team <span class="text-secondary-vivid">*</span></label>
          <select class="usa-select" id="team" name="team" required>
            <option value="">Select a team</option>
            {teamOptions.map((option) => <option value={option}>{option}</option>)}
          </select>
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="projectRole">Project Role <span class="text-secondary-vivid">*</span></label>
          <select class="usa-select" id="projectRole" name="projectRole" required>
            <option value="">Select a Project Role</option>
            {projectRoleOptions.map((option) => <option value={option}>{option}</option>)}
          </select>
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="affiliation">Affiliation/Employer <span class="text-secondary-vivid">*</span></label>
          <select class="usa-select" id="affiliation" name="affiliation" required>
            <option value="">Select an Affiliation/Employer</option>
            {affiliationOptions.map((option) => <option value={option}>{option}</option>)}
          </select>
        </div>
      </div>

      <div class="grid-row grid-gap margin-top-2">
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="professionalTitle">Professional Title</label>
          <input class="usa-input" id="professionalTitle" name="professionalTitle" type="text" placeholder="Enter your title" />
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="alternateEmail">Email with direct access to Google Drive <span class="text-secondary-vivid">*</span></label>
          <input class="usa-input" id="alternateEmail" name="alternateEmail" type="email" required />
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="githubHandle">GitHub Handle <span class="text-secondary-vivid">*</span></label>
          <input class="usa-input" id="githubHandle" name="githubHandle" type="text" required />
        </div>
      </div>
    </fieldset>

    <fieldset class="usa-fieldset margin-top-4">
      <legend class="usa-legend">Section 3</legend>
      <p class="text-base-dark margin-top-1">The BDC Coordinating Center will use your responses to grant access to the resources you need.</p>

      <fieldset class="usa-fieldset">
        <legend class="usa-legend margin-top-2">BDC Jira Access</legend>
        <div class="usa-radio">
          <input class="usa-radio__input" id="jira-yes" type="radio" name="dashboard" value="Yes" />
          <label class="usa-radio__label" for="jira-yes">Yes</label>
        </div>
        <div class="usa-radio">
          <input class="usa-radio__input" id="jira-no" type="radio" name="dashboard" value="No" />
          <label class="usa-radio__label" for="jira-no">No</label>
        </div>
      </fieldset>
    </fieldset>

    <fieldset class="usa-fieldset margin-top-4">
      <legend class="usa-legend">Section 4</legend>
      <p class="text-base-dark margin-top-1">
        This section is for PI and other BDC leadership. These fields are used to link a Project Manager and/or Executive Assistant to your contact card in the
        <a href="/consortium-directory" class="usa-link"> Consortium Directory</a>.
      </p>

      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="pmName">Project Manager Name</label>
          <input class="usa-input" id="pmName" name="projectManagerName" type="text" />
        </div>
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="pmEmail">Project Manager Email</label>
          <input class="usa-input" id="pmEmail" name="projectManagerEmail" type="email" />
        </div>
      </div>

      <div class="grid-row grid-gap margin-top-2">
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="eaName">Executive Assistant Name</label>
          <input class="usa-input" id="eaName" name="executiveAssistantName" type="text" />
        </div>
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="eaEmail">Executive Assistant Email</label>
          <input class="usa-input" id="eaEmail" name="executiveAssistantEmail" type="email" />
        </div>
      </div>
    </fieldset>

    <p class="margin-top-4"><strong>You have reached the end of the BDC Onboarding Form.</strong> Hit Save before Submit if you want to continue later.</p>

    <input type="hidden" name="SecurityID" value="6cd0745d07fa6c0197fd5026cec4bdeaecb09dec" />

    <div class="margin-top-3 display-flex flex-wrap gap-2">
      <button class="usa-button usa-button--outline" type="submit" name="action_saveOnboardingForm">Save</button>
      <button class="usa-button" type="submit" name="action_submitOnboardingForm">Submit</button>
    </div>
  </form>
</section>

<style>
  .onboarding-form-wrapper {
    max-width: 70rem;
  }

  .usa-legend {
    font-weight: 700;
  }

  .gap-2 {
    gap: 0.75rem;
  }
</style>
