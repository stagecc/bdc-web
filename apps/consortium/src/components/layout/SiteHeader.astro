---
import { Image } from "astro:assets";
import bdcLogo from "../../assets/bdc-logo.svg";

const nav = [
  {
    label: "Consortium Resources",
    href: "/consortium-resources",
  },
  {
    label: "Consortium Directory",
    href: "/consortium-directory",
  },
  {
    label: "Monitor Dashboard",
    href: "/monitor-dashboard",
  },
  {
    label: "April 2026 Bi-Annual Meeting",
    href: "/april-2026-meeting",
  },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => pathname === href || pathname.startsWith(href + "/");
---

<header class="usa-header usa-header--basic bg-base-lightest padding-y-2">
  <div class="usa-nav-container display-flex flex-column">
    <a href="/" class="display-flex flex-align-center app-home-link" style="align-self: flex-start;">
      <div class="usa-logo display-none">BioData Catalyst Consortium</div>
      <Image src={bdcLogo} height="75" alt="BDC3 home" />
      <!-- <span class="font-serif-3xl text-base-darker">Consortium</span> -->
    </a>
    <div class="display-flex flex-align-center header-links" style="gap: 0.5rem; align-self: flex-end; margin-top: 1rem;">
      {
        nav.map((item) => (
          <a href={item.href} class={isActive(item.href) ? "active-link" : ""}>
            <span class={isActive(item.href) ? "text-primary" : "text-base"}>{item.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</header>

<style>
  .usa-navbar {
    gap: 2rem;
    padding: 2rem;
  }
  .app-home-link {
    text-decoration: none;
  }
  .font-serif-3xl {
    letter-spacing: 6px;
  }
  .header-links a {
    width: 132px;
    display: inline-block;
    text-align: center;
    text-decoration: none;
  }
  .active-link {
    font-weight: 700;
  }
</style>
