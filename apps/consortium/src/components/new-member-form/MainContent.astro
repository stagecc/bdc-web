---
import { affiliationOptions, collaborationGroups, projectRoleOptions, teamOptions } from "@components/common/formOptions";
---

<section class="new-member-form-wrapper maxw-none">
  <h1>New Member Form</h1>
  <p class="usa-intro margin-top-1">Use this request form to add a new consortium member and assign their team access, role, and collaboration groups.</p>

  <div class="usa-alert usa-alert--info margin-top-2 margin-bottom-4" role="status">
    <div class="usa-alert__body">
      <h2 class="usa-alert__heading">Before you submit</h2>
      <p class="usa-alert__text margin-0">New project managers should be assigned the Project Manager role so they are included in PM meeting invites and can request new consortium members.</p>
    </div>
  </div>

  <form class="usa-form maxw-none" action="#" method="post" novalidate>
    <fieldset class="usa-fieldset">
      <legend class="usa-legend">Member details</legend>

      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="firstName">First Name</label>
          <input class="usa-input" id="firstName" name="firstName" type="text" required />
        </div>

        <div class="tablet:grid-col-6">
          <label class="usa-label" for="lastName">Last Name</label>
          <input class="usa-input" id="lastName" name="lastName" type="text" required />
        </div>
      </div>

      <div class="grid-row grid-gap margin-top-2">
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="email">Email</label>
          <input class="usa-input" id="email" name="email" type="email" required />
        </div>
      </div>

      <div class="usa-checkbox margin-top-2">
        <input class="usa-checkbox__input" id="consortium-wide-opt-out" name="consortiumWideOptOut" type="checkbox" value="1" />
        <label class="usa-checkbox__label" for="consortium-wide-opt-out">Remove this person from consortium-wide emails</label>
      </div>

      <div class="grid-row grid-gap margin-top-3">
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="team">Team</label>
          <select class="usa-select" id="team" name="team" required>
            <option value="">Select a team</option>
            {teamOptions.map((option) => <option value={option}>{option}</option>)}
          </select>
        </div>

        <div class="tablet:grid-col-6">
          <label class="usa-label" for="affiliation">Affiliation/Employer</label>
          <select class="usa-select" id="affiliation" name="affiliation" required>
            <option value="">Select an Affiliation/Employer</option>
            {affiliationOptions.map((option) => <option value={option}>{option}</option>)}
          </select>
        </div>
      </div>

      <div class="margin-top-4">
        <h2 class="font-heading-md margin-bottom-1">Project Role Definitions</h2>
        <ul class="usa-list margin-top-1">
          <li>Principal Investigator = defined as the PI(s) listed on the OTA</li>
          <li>Co-Investigator (Co-I) = defined by the PI of each team, if applicable</li>
          <li>Institution Lead = defined for leads who are not listed on the OTA, if applicable</li>
          <li>BDCatalyst Consortium Member = stakeholder not identified by one of the other listed Project Roles</li>
        </ul>
      </div>

      <div class="margin-top-3">
        <label class="usa-label" for="projectRole">Project Role</label>
        <select class="usa-select" id="projectRole" name="projectRole" required>
          <option value="">Select a Project Role</option>
          {projectRoleOptions.map((option) => <option value={option}>{option}</option>)}
        </select>
        <p class="text-base-dark margin-top-1 font-sans-xs text-italic">Anyone assigned the role of Project Manager will be added to the Project Manager Meeting Invite List.</p>
      </div>

      <fieldset class="usa-fieldset margin-top-3">
        <legend class="usa-legend">Collaboration Groups</legend>
        <div class="grid-row grid-gap">
          {
            collaborationGroups.map((group) => {
              const id = `group-${group
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, "-")
                .replace(/^-|-$/g, "")}`;
              return (
                <div class="tablet:grid-col-6 margin-bottom-1">
                  <div class="usa-checkbox">
                    <input class="usa-checkbox__input" id={id} name="collaborationGroups" type="checkbox" value={group} />
                    <label class="usa-checkbox__label" for={id}>
                      {group}
                    </label>
                  </div>
                </div>
              );
            })
          }
        </div>
        <p class="text-base-dark margin-top-1 font-sans-xs text-italic">Anyone assigned to the Steering Committee or Team Collaboration Meeting groups will be added to the respective meeting invite lists.</p>
      </fieldset>

      <div class="usa-checkbox margin-top-3">
        <input class="usa-checkbox__input" id="steering-committee-invite" name="steeringCommitteeInvite" type="checkbox" value="1" />
        <label class="usa-checkbox__label" for="steering-committee-invite">Invite this person to Steering Committee Meetings</label>
      </div>
      <p class="text-base-dark margin-top-1 font-sans-xs text-italic">Steering Committee Members are automatically assigned to the meeting invitation list. This option allows non-Steering Committee members to also be added.</p>
    </fieldset>

    <div class="margin-top-4 display-flex flex-wrap gap-2">
      <button class="usa-button" type="submit">Submit New Consortia Member</button>
      <button class="usa-button usa-button--outline" type="submit">Submit without sending Onboarding Instructions</button>
    </div>
  </form>
</section>

<style>
  .new-member-form-wrapper {
    max-width: 70rem;
  }

  .usa-legend {
    font-weight: 700;
  }

  .gap-2 {
    gap: 0.75rem;
  }
</style>
