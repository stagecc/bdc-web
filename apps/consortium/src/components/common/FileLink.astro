---
import { Image } from "astro:assets";

import pdfIcon from "../../assets/icons/adobe-pdf.png";
import formsIcon from "../../assets/icons/google-forms.jpg";
import docsIcon from "../../assets/icons/google-docs.png";
import slidesIcon from "../../assets/icons/google-slides.png";
import zipIcon from "../../assets/icons/zip.png";

interface Props {
  href: string;
  type: "pdf" | "forms" | "docs" | "slides" | "zip";
}

const { href, type } = Astro.props;

const ICONS = {
  pdf: pdfIcon,
  forms: formsIcon,
  docs: docsIcon,
  slides: slidesIcon,
  zip: zipIcon,
};

const icon = ICONS[type];
---

<a href={href} class="usa-link display-inline-flex flex-align-center text-no-underline hover:text-underline padding-y-1" target="_blank" rel="noopener noreferrer">
  {icon && <Image src={icon} alt={`${type} icon`} class="width-3 height-4 flex-no-shrink margin-right-2" />}
  <span><slot /></span>
</a>
