---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import { affiliationOptions, collaborationGroups, projectRoleOptions, teamOptions } from "@components/common/formOptions";

const members = await getCollection("members");
members.sort((a, b) => a.data.surname.localeCompare(b.data.surname));

const searchParams = Astro.url.searchParams;

const firstNameQuery = searchParams.get("FirstName")?.trim() ?? "";
const surnameQuery = searchParams.get("Surname")?.trim() ?? "";
const emailQuery = searchParams.get("Email")?.trim() ?? "";
const teamQuery = searchParams.get("Team")?.trim() ?? "";
const affiliationQuery = searchParams.get("Affiliation")?.trim() ?? "";
const projectRoleQuery = searchParams.get("ProjectRole")?.trim() ?? "";
const collaborationGroupQuery = searchParams.get("CollaborationGroup")?.trim() ?? "";

const includesText = (source: string, query: string) => source.toLowerCase().includes(query.toLowerCase());

const filteredMembers = members.filter((member) => {
  if (firstNameQuery && !includesText(member.data.firstName, firstNameQuery)) return false;
  if (surnameQuery && !includesText(member.data.surname, surnameQuery)) return false;
  if (emailQuery && !includesText(member.data.email, emailQuery)) return false;
  if (teamQuery && member.data.team !== teamQuery) return false;
  if (affiliationQuery && member.data.affiliation !== affiliationQuery) return false;
  if (projectRoleQuery && member.data.projectRole !== projectRoleQuery) return false;
  if (collaborationGroupQuery && !includesText(String(member.data.collaborationGroups ?? ""), collaborationGroupQuery)) return false;

  return true;
});
---

<Base title="Consortium Directory">
  <h1>Consortium Directory</h1>

  <form id="directory-filter-form" class="usa-form maxw-none margin-bottom-4" action="/consortium-directory/" method="get">
    <fieldset class="usa-fieldset">
      <legend class="usa-legend">Directory Filters</legend>

      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="FirstName">First Name</label>
          <input class="usa-input" type="text" name="FirstName" id="FirstName" value={firstNameQuery} />
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="Surname">Last Name</label>
          <input class="usa-input" type="text" name="Surname" id="Surname" value={surnameQuery} />
        </div>
        <div class="tablet:grid-col-4">
          <label class="usa-label" for="Email">Email</label>
          <input class="usa-input" type="text" name="Email" id="Email" value={emailQuery} />
        </div>
      </div>

      <div class="grid-row grid-gap margin-top-2">
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="Team">Team</label>
          <select class="usa-select" name="Team" id="Team">
            <option value="">Select a team</option>
            {
              teamOptions.map((option) => (
                <option selected={option === teamQuery} value={option}>
                  {option}
                </option>
              ))
            }
          </select>
        </div>
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="Affiliation">Affiliation/Employer</label>
          <select class="usa-select" name="Affiliation" id="Affiliation">
            <option value="">Select an Affiliation/Employer</option>
            {
              affiliationOptions.map((option) => (
                <option selected={option === affiliationQuery} value={option}>
                  {option}
                </option>
              ))
            }
          </select>
        </div>
      </div>

      <div class="grid-row grid-gap margin-top-2">
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="ProjectRole">Project Role</label>
          <select class="usa-select" name="ProjectRole" id="ProjectRole">
            <option value="">Select a Project Role</option>
            {
              projectRoleOptions.map((option) => (
                <option selected={option === projectRoleQuery} value={option}>
                  {option}
                </option>
              ))
            }
          </select>
        </div>
        <div class="tablet:grid-col-6">
          <label class="usa-label" for="CollaborationGroup">Collaboration Group</label>
          <select class="usa-select" name="CollaborationGroup" id="CollaborationGroup">
            <option value="">Select a Collaboration Group</option>
            {
              collaborationGroups.map((option) => (
                <option selected={option === collaborationGroupQuery} value={option}>
                  {option}
                </option>
              ))
            }
          </select>
        </div>
      </div>
    </fieldset>

    <div class="margin-top-3 display-flex flex-wrap gap-2">
      <button type="submit" class="usa-button">Search</button>
      <a href="/consortium-directory/" class="usa-button usa-button--outline">Reset</a>
    </div>
  </form>

  <p class="font-sans-sm margin-top-0">Showing {filteredMembers.length} of {members.length} members.</p>

  <table id="directory-table" class="usa-table usa-table--borderless usa-table--striped width-full">
    <thead>
      <tr>
        <th scope="col">Name</th>
        <th scope="col">Email</th>
        <th scope="col">STAGE Team</th>
        <th scope="col">Project Role</th>
        <th scope="col">Employer/Affiliation</th>
      </tr>
    </thead>
    <tbody>
      {
        filteredMembers.map((member) => (
          <tr>
            <td class="text-bold">
              {member.data.firstName} {member.data.surname}
            </td>
            <td>{member.data.email}</td>
            <td>{member.data.team}</td>
            <td>{member.data.projectRole}</td>
            <td>{member.data.affiliation}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</Base>

<style is:global>
  .gap-2 {
    gap: 0.75rem;
  }

  #directory-table tbody td {
    border-bottom-color: transparent;
  }

  #directory-table {
    table-layout: fixed;
  }

  #directory-table th,
  #directory-table td {
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    vertical-align: top;
  }

  #directory-table th:nth-child(2),
  #directory-table td:nth-child(2) {
    width: 24%;
  }

  #directory-table th:nth-child(5),
  #directory-table td:nth-child(5) {
    width: 24%;
  }
</style>
